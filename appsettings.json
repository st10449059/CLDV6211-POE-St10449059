{
  "ConnectionStrings": {
    /* * DefaultConnection: Defines the parameters for connecting to the 
       * SQL LocalDB instance (Microsoft, 2023).
    */
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EventEase_FinalVersion;Trusted_Connection=True;MultipleActiveResultSets=true",

    /* * AzureBlobStorage: Development connection string used to connect to 
       * the Azurite local storage emulator for blob handling (Microsoft, 2023).
    */
    "AzureBlobStorage": "UseDevelopmentStorage=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

