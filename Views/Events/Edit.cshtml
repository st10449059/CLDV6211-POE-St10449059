@model CLDV6211_Assignment_Part_1_St10449059.Models.Event

@{
    ViewData["Title"] = "Edit";
}

<h1 class="display-6">Edit Event</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        @* FIXED: Added enctype to allow new image uploads to Blob Storage *@
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            @* Hidden fields preserve data that isn't being edited directly *@
            <input type="hidden" asp-for="EventId" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="form-group mb-3">
                <label asp-for="EventName" class="control-label fw-bold"></label>
                <input asp-for="EventName" class="form-control" />
                <span asp-validation-for="EventName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EventDate" class="control-label fw-bold"></label>
                <input asp-for="EventDate" class="form-control" />
                <span asp-validation-for="EventDate" class="text-danger"></span>
            </div>

            @* Display the current image so the user knows what they are changing *@
            <div class="form-group mb-3">
                <label class="control-label fw-bold d-block">Current Image</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="Event Image" class="img-thumbnail mb-2" style="max-height: 150px;" />
                }
                else
                {
                    <p class="text-muted small">No image currently assigned.</p>
                }
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                <small class="text-muted">Upload a new file to replace the current image.</small>
            </div>

            <div class="form-group mb-4">
                <label asp-for="VenueId" class="control-label fw-bold">Venue</label>
                @* FIXED: Using double quotes and casting to SelectList for stability *@
                <select asp-for="VenueId" class="form-select" asp-items="@(ViewData["VenueId"] as SelectList)"></select>
                <span asp-validation-for="VenueId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary px-4" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}