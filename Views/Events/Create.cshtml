@model CLDV6211_Assignment_Part_1_St10449059.Models.Event

@{
    ViewData["Title"] = "Create";
}
<h1 class="display-6">Create Event</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="form-group mb-3">
                <label asp-for="EventName" class="control-label fw-bold"></label>
                <input asp-for="EventName" class="form-control" placeholder="e.g. Annual Gala" />
                <span asp-validation-for="EventName" class="text-danger"></span>
            </div>

            @* NEW: Event Type Dropdown *@
            <div class="form-group mb-3">
                <label asp-for="EventTypeId" class="control-label fw-bold"></label>
                <select asp-for="EventTypeId" class="form-select" asp-items="@(ViewData["EventTypeId"] as SelectList)" required>
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="EventTypeId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EventDate" class="control-label fw-bold">Select Date and Time</label>
                <input asp-for="EventDate" type="datetime-local" class="form-control" required />
                <span asp-validation-for="EventDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label fw-bold">Upload Event Banner</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="VenueId" class="control-label fw-bold">Assign Venue</label>
                <select asp-for="VenueId" class="form-select" asp-items="@(ViewData["VenueId"] as SelectList)" required>
                    <option value="">-- Choose a Venue --</option>
                </select>
                <span asp-validation-for="VenueId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create Event" class="btn btn-primary px-4 shadow-sm" />
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}