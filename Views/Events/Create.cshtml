@model CLDV6211_Assignment_Part_1_St10449059.Models.Event

@{
    ViewData["Title"] = "Create";
}

<h1 class="display-6">Create Event</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data">
            @* CRITICAL: This line displays the "Double Booking" alert message *@
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="form-group mb-3">
                <label asp-for="EventName" class="control-label fw-bold"></label>
                <input asp-for="EventName" class="form-control" />
                <span asp-validation-for="EventName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EventDate" class="control-label fw-bold"></label>
                <input asp-for="EventDate" class="form-control" />
                <span asp-validation-for="EventDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label fw-bold">Event Image</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="VenueId" class="control-label fw-bold">Venue</label>
                <select asp-for="VenueId" class="form-select" asp-items="@(ViewData["VenueId"] as SelectList)">
                    <option value="">-- Select Venue --</option>
                </select>
                <span asp-validation-for="VenueId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary px-4" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}