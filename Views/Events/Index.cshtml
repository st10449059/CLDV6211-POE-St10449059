@model IEnumerable<CLDV6211_Assignment_Part_1_St10449059.Models.Event>

@{
    ViewData["Title"] = "Index";
}

<h1 class="display-6">Events</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Validation Error:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-outline-success">Create New Event</a>
</p>

@* NEW: Advanced Filtering UI *@
<div class="card mb-4 shadow-sm">
    <div class="card-body bg-light">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-bold">Event Type</label>
                <select name="eventTypeId" class="form-select" asp-items="@(ViewData["EventTypeId"] as SelectList)">
                    <option value="">-- All Types --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Start Date</label>
                <input type="date" name="startDate" class="form-control" value="@ViewData["StartDate"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">End Date</label>
                <input type="date" name="endDate" class="form-control" value="@ViewData["EndDate"]" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Venue</label>
                <select name="venueId" class="form-select" asp-items="@(ViewData["VenueId"] as SelectList)">
                    <option value="">-- All Venues --</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
            <div class="col-12 mt-2 text-end">
                <a asp-action="Index" class="text-decoration-none text-muted">Clear Filters</a>
            </div>
        </form>
    </div>
</div>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.EventName)</th>
            <th>Type</th>
            <th>@Html.DisplayNameFor(model => model.EventDate)</th>
            <th>Image</th>
            <th>Venue</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">@Html.DisplayFor(modelItem => item.EventName)</td>
                <td><span class="badge bg-secondary">@Html.DisplayFor(modelItem => item.EventType.Name)</span></td>
                <td>@Html.DisplayFor(modelItem => item.EventDate)</td>
                <td>
                    <img src="@item.ImageUrl" style="height:50px; width:auto;" class="rounded" alt="Event Image" />
                </td>
                <td>@Html.DisplayFor(modelItem => item.Venue.VenueName)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.EventId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.EventId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.EventId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>