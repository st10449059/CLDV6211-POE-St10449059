@model IEnumerable<CLDV6211_Assignment_Part_1_St10449059.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1 class="display-6">Booking Specialist View</h1>
<hr />

@* Requirement: Simple search function via bookingID or Event Name *@
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group" style="max-width: 600px;">
        <input type="text" name="searchString" class="form-control" placeholder="Search by Booking ID or Event Name..." value="@ViewData["CurrentFilter"]" />
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<table class="table table-bordered table-hover shadow-sm">
    <thead class="table-secondary">
        <tr>
            <th>Booking ID</th>
            <th>Attendee Name</th>
            @* Requirement: Consolidate information from Venue and Event tables *@
            <th>Event Name</th>
            <th>Event Date</th>
            <th>Venue Location</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.BookingId)</td>
                <td class="fw-bold">@Html.DisplayFor(modelItem => item.AttendeeName)</td>
                <td>@Html.DisplayFor(modelItem => item.Event.EventName)</td>
                <td>@Html.DisplayFor(modelItem => item.Event.EventDate)</td>
                <td>@Html.DisplayFor(modelItem => item.Event.Venue.Location)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
